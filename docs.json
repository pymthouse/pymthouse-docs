{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PymtHouse",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Builder guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Concepts",
            "pages": [
              "integration/client-model",
              "integration/sdk",
              "integration/api-keys"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "integration/machine-access",
              "integration/interactive-login",
              "integration/device-flow",
              "integration/token-exchange"
            ]
          },
          {
            "group": "Builder API",
            "pages": [
              "integration/user-management",
              "integration/user-tokens",
              "integration/allowances",
              "integration/signer-routing"
            ]
          },
          {
            "group": "Billing API",
            "pages": [
              "integration/billing",
              "integration/plans",
              "integration/usage-api"
            ]
          },
          {
            "group": "Migration",
            "pages": [
              "integration/deprecated"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "vscode"]
  }
}
